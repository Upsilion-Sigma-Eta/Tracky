<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Tracky.App.Controls"
        xmlns:vm="using:Tracky.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1600"
        d:DesignHeight="980"
        x:Class="Tracky.App.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1600"
        Height="980"
        MinWidth="1260"
        MinHeight="820"
        Background="{StaticResource TrackyCanvasBrush}"
        Icon="/Assets/avalonia-logo.ico"
        Title="Tracky">
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+1" Command="{Binding ShowIssuesCommand}" />
        <KeyBinding Gesture="Ctrl+2" Command="{Binding ShowProjectsCommand}" />
        <KeyBinding Gesture="Ctrl+R" Command="{Binding RefreshCommand}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding CreateIssueCommand}" />
        <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportSelectionCommand}" />
    </Window.KeyBindings>

    <Window.Styles>
        <Style Selector="Border.surface">
            <Setter Property="Background" Value="{StaticResource TrackySurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="TextBlock.hero-title">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
            <Setter Property="LineHeight" Value="32" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
        </Style>

        <Style Selector="TextBlock.metric-value">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
        </Style>

        <Style Selector="TextBlock.metric-label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TrackyMutedInkBrush}" />
        </Style>

        <Style Selector="TextBlock.body">
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="TextBlock.render-block">
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="LineHeight" Value="21" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style Selector="TextBlock.render-block.heading1">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="30" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style Selector="TextBlock.render-block.heading2">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="26" />
            <Setter Property="Margin" Value="0,4,0,10" />
        </Style>

        <Style Selector="TextBlock.render-block.heading3">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="23" />
            <Setter Property="Margin" Value="0,3,0,8" />
        </Style>

        <Style Selector="TextBlock.render-block.code">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Menlo" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="LineHeight" Value="19" />
        </Style>

        <Style Selector="TextBlock.render-block.quote">
            <Setter Property="Foreground" Value="{StaticResource TrackyMutedInkBrush}" />
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{StaticResource TrackyMutedInkBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Menlo" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TrackyMutedInkBrush}" />
        </Style>

        <!-- Avalonia Fluent 기본 Button 스타일은 :pointerover 상태에서 내부 ContentPresenter 배경을 ButtonBackgroundPointerOver로 덮어쓴다.
             따라서 Button.* 에만 Background를 설정하면 호버 때 원치 않는 기본 색이 그 위에 그려진다.
             모든 custom Button 클래스는 /template/ ContentPresenter#PART_ContentPresenter 셀렉터로 직접 덮어써서 톤 일관성을 유지한다. -->
        <Style Selector="Button.nav-item">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TrackyNavMutedInkBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <Style Selector="Button.nav-item /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyNavItemHoverBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyNavBorderBrush}" />
        </Style>

        <Style Selector="Button.nav-item:pointerover">
            <Setter Property="Foreground" Value="{StaticResource TrackyNavInkBrush}" />
        </Style>

        <Style Selector="Button.nav-item:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyNavHoverBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyNavBorderBrush}" />
        </Style>

        <Style Selector="Button.nav-item.active">
            <Setter Property="Foreground" Value="{StaticResource TrackyNavInkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.nav-item.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyNavActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyNavActiveBrush}" />
        </Style>

        <Style Selector="Button.nav-item.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyNavActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyNavActiveBrush}" />
        </Style>

        <Style Selector="Button.nav-item:disabled">
            <Setter Property="Opacity" Value="0.55" />
        </Style>

        <Style Selector="Button.scope-chip">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="{StaticResource TrackyMutedInkBrush}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="Button.scope-chip /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyBorderBrush}" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button.scope-chip:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackySurfaceSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyBorderBrush}" />
        </Style>

        <Style Selector="Button.scope-chip:pointerover">
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
        </Style>

        <Style Selector="Button.scope-chip.active">
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.scope-chip.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyAccentBrush}" />
        </Style>

        <Style Selector="Button.scope-chip.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyAccentBrush}" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.primary /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyOpenBrush}" />
            <Setter Property="BorderBrush" Value="#1A7F37" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1F883D" />
            <Setter Property="BorderBrush" Value="#1A7F37" />
        </Style>

        <Style Selector="Button.primary:pointerover">
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#137733" />
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.secondary /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackySurfaceStrongBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyBorderBrush}" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyBorderBrush}" />
        </Style>

        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
        </Style>

        <Style Selector="Button.secondary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyBorderMutedBrush}" />
        </Style>

        <Style Selector="TextBox.search-box">
            <Setter Property="Background" Value="{StaticResource TrackySurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="TextBox.search-box:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{StaticResource TrackyAccentBrush}" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- ListBoxItem의 hover/selected 배경 또한 Fluent 기본 테마가 /template/ ContentPresenter 경로로 주입하므로 같은 경로로 덮어써야 한다. -->
        <Style Selector="ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyRowHoverBrush}" />
        </Style>

        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyAccentSoftBrush}" />
        </Style>

        <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyAccentSoftBrush}" />
        </Style>

        <Style Selector="ScrollBar">
            <Setter Property="Opacity" Value="0.8" />
        </Style>

        <Style Selector="Button.github-tab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="Button.github-tab /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style Selector="Button.github-tab:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyRowHoverBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyBorderMutedBrush}" />
        </Style>

        <Style Selector="Button.github-tab:pointerover">
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
        </Style>

        <Style Selector="Button.github-tab.active">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
        </Style>

        <Style Selector="Button.github-tab.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#FB8500" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
        </Style>

        <Style Selector="Button.github-tab.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TrackyRowHoverBrush}" />
            <Setter Property="BorderBrush" Value="#FB8500" />
        </Style>

        <Style Selector="Button.github-tab:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>

        <Style Selector="Button.header-filter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TrackyMutedInkBrush}" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style Selector="ComboBox.header-filter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TrackyMutedInkBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- 이슈 행은 GitHub Issues 목록의 subtle hover 피드백을 흉내내기 위해 배경이 RowHoverBrush로 전환된다. -->
        <Style Selector="Border.issue-row">
            <Setter Property="Background" Value="{StaticResource TrackySurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TrackyBorderMutedBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="16,12" />
        </Style>

        <Style Selector="ListBoxItem:pointerover Border.issue-row">
            <Setter Property="Background" Value="{StaticResource TrackyRowHoverBrush}" />
        </Style>

        <Style Selector="ListBoxItem:selected Border.issue-row">
            <Setter Property="Background" Value="{StaticResource TrackyAccentSoftBrush}" />
        </Style>

        <Style Selector="TextBlock.issue-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TrackyInkBrush}" />
        </Style>

        <Style Selector="ListBoxItem:pointerover TextBlock.issue-title">
            <Setter Property="Foreground" Value="{StaticResource TrackyAccentBrush}" />
        </Style>

        <!-- GitHub 라벨 칩: 개별 색상 바탕 + 반투명 링 border + 대비 기반 텍스트. LabelChipViewModel이 색을 계산해 내려준다. -->
        <Style Selector="Border.label-chip">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,1" />
            <Setter Property="Margin" Value="0,0,6,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.label-chip-text">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Border.state-pill">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="12,5" />
        </Style>

        <Style Selector="TextBlock.state-pill-text">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Border.meta-chip">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
        </Style>
    </Window.Styles>

    <!-- GitHub repository 화면처럼 왼쪽 앱 셸을 두지 않고, 상단 repository header와 tab navigation을 기본 조작 경로로 삼는다. -->
    <Grid ColumnDefinitions="*" ColumnSpacing="0" Margin="0">
        <Grid Grid.Column="0"
              RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="16"
              IsVisible="{Binding IsIssueListViewVisible}">
            <Border BorderBrush="{StaticResource TrackyBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="0,0,0,8">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Classes="hero-title" Text="{Binding WorkspaceName}" />
                                <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                        BorderBrush="{StaticResource TrackyBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="999"
                                        Padding="8,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Classes="muted" FontSize="12" Text="Local" />
                                </Border>
                            </StackPanel>
                            <TextBlock Classes="muted"
                                       Text="{Binding WorkspaceDescription}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Classes="mono"
                                   Width="320"
                                   Text="{Binding DatabasePath}"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="2">
                        <Button Classes="github-tab" Content="Code" IsEnabled="False" />
                        <Button Classes="github-tab"
                                Classes.active="{Binding IsIssuesViewActive}"
                                Command="{Binding ShowIssuesCommand}"
                                Content="{Binding TotalIssues, StringFormat='Issues  {0}'}" />
                        <Button Classes="github-tab" Content="Pull requests" IsEnabled="False" />
                        <Button Classes="github-tab"
                                Classes.active="{Binding IsProjectsViewActive}"
                                Command="{Binding ShowProjectsCommand}"
                                Content="Repositories" />
                        <Button Classes="github-tab" Content="Milestones" IsEnabled="False" />
                        <Button Classes="github-tab" Content="Insights" IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <Button Classes="secondary"
                        Content="Filters"
                        IsEnabled="False" />
                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Classes="search-box"
                         PlaceholderText="is:issue state:open label:bug assignee:me due:today"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <Button x:Name="RefreshWorkspaceButton"
                        Grid.Column="2"
                        Classes="secondary"
                        Command="{Binding RefreshCommand}"
                        Content="Search" />
                <Button Grid.Column="3"
                        Classes="secondary"
                        Content="Labels"
                        IsEnabled="False" />
                <Button Grid.Column="4"
                        Classes="secondary"
                        Content="Milestones"
                        IsEnabled="False" />
                <Button Grid.Column="5"
                        Classes="primary"
                        Command="{Binding PrepareNewIssueCommand}"
                        Content="New issue" />
            </Grid>

            <Border Grid.Row="2"
                    Classes="surface"
                    ClipToBounds="True"
                    Padding="0">
                <Grid RowDefinitions="Auto,Auto,*">
                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            Padding="14,8">
                        <WrapPanel>
                            <Button Classes="scope-chip"
                                    Classes.active="{Binding IsAllScopeActive}"
                                    Command="{Binding ShowAllCommand}"
                                    Margin="0,0,8,8"
                                    Content="{Binding TotalIssues, StringFormat='All {0}'}" />
                            <Button Classes="scope-chip"
                                    Classes.active="{Binding IsOpenScopeActive}"
                                    Command="{Binding ShowOpenCommand}"
                                    Margin="0,0,8,8"
                                    Content="{Binding OpenIssues, StringFormat='Open {0}'}" />
                            <Button Classes="scope-chip"
                                    Classes.active="{Binding IsClosedScopeActive}"
                                    Command="{Binding ShowClosedCommand}"
                                    Margin="0,0,8,8"
                                    Content="{Binding ClosedIssues, StringFormat='Closed {0}'}" />

                            <ComboBox Classes="header-filter"
                                      ItemsSource="{Binding AvailableIssueAssigneeFilters}"
                                      Margin="0,0,8,8"
                                      SelectedItem="{Binding SelectedIssueAssigneeFilter}" />
                            <ComboBox Classes="header-filter"
                                      ItemsSource="{Binding AvailableIssueLabelFilters}"
                                      Margin="0,0,8,8"
                                      SelectedItem="{Binding SelectedIssueLabelFilter}" />
                            <ComboBox Classes="header-filter"
                                      ItemsSource="{Binding AvailableIssueProjectFilters}"
                                      Margin="0,0,8,8"
                                      SelectedItem="{Binding SelectedIssueProjectFilter}" />
                            <ComboBox Classes="header-filter"
                                      ItemsSource="{Binding AvailableIssueMilestoneFilters}"
                                      Margin="0,0,8,8"
                                      SelectedItem="{Binding SelectedIssueMilestoneFilter}" />
                            <ComboBox Classes="header-filter"
                                      ItemsSource="{Binding AvailableIssueTypeFilters}"
                                      Margin="0,0,8,8"
                                      SelectedItem="{Binding SelectedIssueTypeFilter}" />
                            <ComboBox Classes="header-filter"
                                      ItemsSource="{Binding AvailableIssueSortOptions}"
                                      Margin="0,0,8,8"
                                      SelectedItem="{Binding SelectedIssueSortOption}" />
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="0,1,0,1"
                            Padding="14,8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="muted"
                                       Text="{Binding IssueListSummaryText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Grid.Column="1"
                                       Classes="muted"
                                       Text="{Binding UpcomingIssues, StringFormat='Upcoming {0}'}" />
                        </Grid>
                    </Border>

                    <ListBox x:Name="IssueListBox"
                             Grid.Row="2"
                             ItemsSource="{Binding VisibleIssues}"
                             SelectedItem="{Binding SelectedIssue, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:IssueCardViewModel">
                                <Border Classes="issue-row"
                                        BorderBrush="{Binding CardBorderBrush}">
                                    <Grid ColumnDefinitions="28,*,Auto" ColumnSpacing="12">
                                        <Border Width="20"
                                                Height="20"
                                                CornerRadius="10"
                                                Background="{Binding StateIconBackground}"
                                                VerticalAlignment="Top">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding StateIconForeground}"
                                                       Text="{Binding StateIconText}" />
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <WrapPanel>
                                                <TextBlock Classes="issue-title"
                                                           Margin="0,0,8,4"
                                                           Text="{Binding Title}"
                                                           TextWrapping="Wrap" />
                                                <Border Background="{Binding PriorityBadgeBackground}"
                                                        CornerRadius="999"
                                                        Margin="0,0,6,4"
                                                        Padding="8,2">
                                                    <TextBlock FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding PriorityBadgeForeground}"
                                                               Text="{Binding PriorityText}" />
                                                </Border>
                                                <ItemsControl ItemsSource="{Binding LabelChips}"
                                                              IsVisible="{Binding HasLabels}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:LabelChipViewModel">
                                                            <Border Classes="label-chip"
                                                                    Background="{Binding Background}"
                                                                    BorderBrush="{Binding BorderBrush}">
                                                                <TextBlock Classes="label-chip-text"
                                                                           Text="{Binding Name}"
                                                                           Foreground="{Binding Foreground}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </WrapPanel>

                                            <TextBlock Classes="muted"
                                                       Text="{Binding GitHubListMetaText}" />
                                            <WrapPanel>
                                                <TextBlock Classes="muted"
                                                           Margin="0,0,12,0"
                                                           Text="{Binding GitHubListSecondaryText}" />
                                                <Border Background="{Binding DueBadgeBackground}"
                                                        CornerRadius="999"
                                                        Padding="8,2"
                                                        IsVisible="{Binding HasDueDate}">
                                                    <TextBlock FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding DueBadgeForeground}"
                                                               Text="{Binding DueText}" />
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="12"
                                                    VerticalAlignment="Top">
                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasComments}"
                                                       Text="{Binding CommentBadgeText, StringFormat='Comments {0}'}" />
                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasAttachments}"
                                                       Text="{Binding AttachmentsText}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Row="3"
                  ColumnDefinitions="1.15*,0.85*"
                  ColumnSpacing="14">
                <Border Classes="surface"
                        Padding="18"
                        IsVisible="{Binding IsQuickCaptureVisible}">
                    <StackPanel Spacing="12">
                        <!-- GitHub의 New issue 작성 흐름처럼 목록 화면 아래에서 제목, 본문, 메타데이터를 한 번에 입력한다. -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="section-title" Text="New issue" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableIssueContentFormats}"
                                      SelectedItem="{Binding DraftIssueContentFormat}" />
                        </Grid>
                        <TextBox x:Name="QuickCaptureTitleBox"
                                 PlaceholderText="Title"
                                 Text="{Binding DraftTitle, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox x:Name="QuickCaptureDescriptionBox"
                                 AcceptsReturn="True"
                                 MinHeight="118"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 PlaceholderText="Write the issue body in Markdown or HTML."
                                 Text="{Binding DraftDescription}" />
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                            <TextBox PlaceholderText="Assignee"
                                     Text="{Binding DraftAssignee}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailablePriorities}"
                                      SelectedItem="{Binding DraftPriority}" />
                            <TextBox Grid.Column="2"
                                     PlaceholderText="Project"
                                     Text="{Binding DraftProjectName}" />
                            <DatePicker Grid.Column="3"
                                        SelectedDate="{Binding DraftDueDate}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <TextBox PlaceholderText="Milestone"
                                     Text="{Binding DraftMilestoneName}" />
                            <TextBox Grid.Column="1"
                                     PlaceholderText="Issue type"
                                     Text="{Binding DraftIssueTypeName}" />
                            <TextBox Grid.Column="2"
                                     PlaceholderText="Labels"
                                     Text="{Binding DraftLabels}" />
                        </Grid>
                        <Button x:Name="CreateIssueButton"
                                Classes="primary"
                                HorizontalAlignment="Right"
                                Command="{Binding CreateIssueCommand}"
                                Content="Submit new issue" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Classes="surface"
                        Padding="18">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="section-title" Text="Issue tools" />
                        <TextBlock x:Name="DetailStatusMessageText"
                                   Classes="muted"
                                   Text="{Binding DetailStatusMessage}"
                                   TextWrapping="Wrap" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBox PlaceholderText="Saved search name"
                                     Text="{Binding DraftSavedIssueSearchName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button x:Name="SaveIssueSearchButton"
                                    Grid.Column="1"
                                    Classes="secondary"
                                    Command="{Binding SaveIssueSearchCommand}"
                                    Content="Save search" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding SavedIssueSearches}"
                                      IsVisible="{Binding HasSavedIssueSearches}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SavedIssueSearchViewModel">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,0,0,8">
                                        <TextBlock Classes="muted"
                                                   Text="{Binding QueryText}"
                                                   TextWrapping="Wrap" />
                                        <Button Grid.Column="1"
                                                Classes="secondary"
                                                Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).ApplySavedIssueSearchCommand}"
                                                CommandParameter="{Binding}"
                                                Content="Apply" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <ComboBox ItemsSource="{Binding AvailableExportFormats}"
                                      SelectedItem="{Binding DraftExportFormat}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableExportBodyFormats}"
                                      SelectedItem="{Binding DraftExportBodyFormat}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="10">
                            <CheckBox Content="Comments"
                                      IsChecked="{Binding DraftExportIncludeComments}" />
                            <CheckBox Grid.Column="1"
                                      Content="Activity"
                                      IsChecked="{Binding DraftExportIncludeActivity}" />
                            <CheckBox Grid.Column="2"
                                      Content="Attachments"
                                      IsChecked="{Binding DraftExportIncludeAttachments}" />
                            <Button x:Name="ExportSelectionButton"
                                    Grid.Column="3"
                                    Classes="secondary"
                                    HorizontalAlignment="Right"
                                    Command="{Binding ExportSelectionCommand}"
                                    Content="Export" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBox PlaceholderText="Export preset name"
                                     Text="{Binding ExportPresetName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button x:Name="SaveExportPresetButton"
                                    Grid.Column="1"
                                    Classes="secondary"
                                    Command="{Binding SaveExportPresetCommand}"
                                    Content="Save preset" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <ComboBox ItemsSource="{Binding AvailableThemePreferences}"
                                      SelectedItem="{Binding SelectedThemePreference}" />
                            <Button x:Name="SavePreferencesButton"
                                    Grid.Column="1"
                                    Classes="secondary"
                                    Command="{Binding SavePreferencesCommand}"
                                    Content="Save preferences" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Column="0"
              RowDefinitions="Auto,*"
              RowSpacing="16"
              IsVisible="{Binding IsIssueDetailViewActive}">
            <Border BorderBrush="{StaticResource TrackyBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="0,0,0,12">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Button x:Name="BackToIssueListButton"
                                Classes="secondary"
                                Command="{Binding BackToIssueListCommand}"
                                Content="Back to issues" />
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Classes="mono"
                                       Text="{Binding DetailStatusMessage}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="muted"
                                       Text="Issue detail"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Classes="primary"
                                Command="{Binding PrepareNewIssueCommand}"
                                Content="New issue" />
                    </Grid>

                    <ContentControl x:Name="SelectedIssueDetailContent"
                                    Grid.Row="1"
                                    Content="{Binding SelectedIssueDetail}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate x:DataType="vm:IssueDetailViewModel">
                                <StackPanel Spacing="10">
                                    <!-- 상세 헤더는 GitHub처럼 제목과 #번호가 같은 줄, 상태/메타는 아래 줄에 둬 위계를 분명히 한다. -->
                                    <WrapPanel>
                                        <TextBlock Classes="hero-title"
                                                   Text="{Binding Summary.Title}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock FontSize="26"
                                                   FontWeight="Light"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TrackyMutedInkBrush}"
                                                   Text="{Binding Summary.NumberText}" />
                                    </WrapPanel>
                                    <WrapPanel>
                                        <Border Classes="state-pill"
                                                Background="{Binding Summary.StateBadgeBackground}"
                                                Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <TextBlock FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Summary.StateBadgeForeground}"
                                                           Text="{Binding Summary.StateIconText}" />
                                                <TextBlock Classes="state-pill-text"
                                                           Foreground="{Binding Summary.StateBadgeForeground}"
                                                           Text="{Binding Summary.StateText}" />
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Classes="muted"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,0,0"
                                                   Text="{Binding Summary.GitHubListMetaText}" />
                                    </WrapPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,300"
                  ColumnSpacing="14">
                <ScrollViewer>
                <ContentControl Content="{Binding SelectedIssueDetail}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:IssueDetailViewModel">
                            <StackPanel Spacing="14">
                                <Border Classes="surface" Padding="18">
                                    <StackPanel Spacing="12">
                                        <!-- GitHub Issue 상세처럼 본문, 언어 배지, 댓글 흐름을 상세 페이지 안에서 바로 읽고 수정하게 한다. -->
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                            <StackPanel Spacing="8">
                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                                    <TextBlock Classes="section-title" Text="Description" />
                                                    <Border Grid.Column="1"
                                                            Background="{StaticResource TrackyAccentSoftBrush}"
                                                            BorderBrush="{StaticResource TrackyAccentBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="999"
                                                            Padding="9,3">
                                                        <TextBlock Text="{Binding DescriptionFormatText}"
                                                                   Foreground="{StaticResource TrackyAccentBrush}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                    <Button x:Name="DescriptionEditButton"
                                                            Grid.Column="2"
                                                            Classes="secondary"
                                                            Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).StartDescriptionEditCommand}"
                                                            Content="Edit"
                                                            IsVisible="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).IsDescriptionReadMode}" />
                                                    <StackPanel Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                Spacing="8"
                                                                IsVisible="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).IsDescriptionEditMode}">
                                                        <Button Classes="primary"
                                                                Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).UpdateSelectedIssueCommand}"
                                                                Content="Save" />
                                                        <Button Classes="secondary"
                                                                Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).CancelDescriptionEditCommand}"
                                                                Content="Cancel" />
                                                    </StackPanel>
                                                </Grid>
                                                <!-- 로컬 앱에서는 WebView가 원문 HTML/CSS를 직접 그려 GitHub issue body에 가까운 읽기 경험을 만든다. -->
                                                <controls:IssueHtmlPreview HtmlContent="{Binding DescriptionHtmlDocument}"
                                                                           FallbackText="{Binding DescriptionFallbackText}"
                                                                           PreviewHeight="{Binding DescriptionPreviewHeight}"
                                                                           IsVisible="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).IsDescriptionReadMode}" />
                                                <Grid RowDefinitions="Auto,Auto"
                                                      RowSpacing="8"
                                                      IsVisible="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).IsDescriptionEditMode}">
                                                    <!-- 본문 원문 편집은 메타데이터 사이드바가 아니라 body card 안에서 처리해 읽기와 수정의 문맥을 붙인다. -->
                                                    <ComboBox Width="160"
                                                              HorizontalAlignment="Left"
                                                              ItemsSource="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).AvailableIssueContentFormats}"
                                                              SelectedItem="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).EditDescriptionFormat}" />
                                                    <TextBox x:Name="DescriptionEditSourceBox"
                                                             Grid.Row="1"
                                                             AcceptsReturn="True"
                                                             MinHeight="170"
                                                             TextWrapping="Wrap"
                                                             VerticalContentAlignment="Top"
                                                             PlaceholderText="Edit the issue body source in Markdown or HTML."
                                                             Text="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).EditDescription}" />
                                                </Grid>
                                            </StackPanel>
                                            <WrapPanel Grid.Column="1">
                                                <Border Background="{Binding Summary.PriorityBadgeBackground}"
                                                        CornerRadius="999"
                                                        Margin="0,0,8,8"
                                                        Padding="10,5">
                                                    <TextBlock Text="{Binding Summary.PriorityText}"
                                                               Foreground="{Binding Summary.PriorityBadgeForeground}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                                <Border Background="{Binding Summary.DueBadgeBackground}"
                                                        CornerRadius="999"
                                                        Margin="0,0,0,8"
                                                        Padding="10,5"
                                                        IsVisible="{Binding Summary.HasDueDate}">
                                                    <TextBlock Text="{Binding Summary.DueText}"
                                                               Foreground="{Binding Summary.DueBadgeForeground}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </WrapPanel>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Summary.LabelChips}"
                                                      IsVisible="{Binding Summary.HasLabels}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:LabelChipViewModel">
                                                    <Border Classes="label-chip"
                                                            Background="{Binding Background}"
                                                            BorderBrush="{Binding BorderBrush}"
                                                            Margin="0,0,8,6"
                                                            Padding="10,3">
                                                        <TextBlock Classes="label-chip-text"
                                                                   Text="{Binding Name}"
                                                                   Foreground="{Binding Foreground}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Classes="surface" Padding="18">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="*,160" ColumnSpacing="10">
                                            <TextBlock Classes="section-title" Text="Comment" />
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).AvailableIssueContentFormats}"
                                                      SelectedItem="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).DraftCommentFormat}" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="2">
                                            <!-- Write/Preview 탭은 저장 전 댓글도 실제 렌더링 경로로 확인하게 만드는 GitHub식 작성 흐름이다. -->
                                            <Button x:Name="CommentWriteTabButton"
                                                    Classes="github-tab"
                                                    Classes.active="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).IsCommentWriteMode}"
                                                    Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).ShowCommentWriteCommand}"
                                                    Content="Write" />
                                            <Button x:Name="CommentPreviewTabButton"
                                                    Classes="github-tab"
                                                    Classes.active="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).IsCommentPreviewMode}"
                                                    Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).ShowCommentPreviewCommand}"
                                                    Content="Preview" />
                                        </StackPanel>
                                        <Grid ColumnDefinitions="160,*"
                                              ColumnSpacing="10"
                                              IsVisible="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).IsCommentWriteMode}">
                                            <TextBox PlaceholderText="Author"
                                                     Text="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).DraftCommentAuthor}" />
                                            <TextBox x:Name="DetailPageCommentBodyBox"
                                                     Grid.Column="1"
                                                     AcceptsReturn="True"
                                                     MinHeight="92"
                                                     TextWrapping="Wrap"
                                                     VerticalContentAlignment="Top"
                                                     PlaceholderText="Write a comment in Markdown or HTML."
                                                     Text="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).DraftCommentBody}" />
                                        </Grid>
                                        <ContentControl x:Name="CommentPreviewContent"
                                                        IsVisible="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).IsCommentPreviewMode}">
                                            <controls:IssueHtmlPreview HtmlContent="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).DraftCommentPreviewHtmlDocument}"
                                                                       FallbackText="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).DraftCommentPreviewFallbackText}"
                                                                       PreviewHeight="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).DraftCommentPreviewHeight}" />
                                        </ContentControl>
                                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="10">
                                            <Button x:Name="DetailPageAddCommentButton"
                                                    Classes="primary"
                                                    Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).AddCommentCommand}"
                                                    Content="Comment" />
                                            <Button x:Name="DetailPageAttachFileButton"
                                                    Grid.Column="1"
                                                    Classes="secondary"
                                                    Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).AttachFileCommand}"
                                                    Content="Attach file" />
                                            <ComboBox x:Name="ComposerCloseReasonComboBox"
                                                      Grid.Column="2"
                                                      Width="156"
                                                      ItemsSource="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).AvailableCloseReasons}"
                                                      SelectedItem="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).SelectedCloseReason}"
                                                      IsVisible="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).CanChooseCloseReason}" />
                                            <Button Grid.Column="3"
                                                    Classes="secondary"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).ToggleSelectedIssueStateCommand}"
                                                    Content="{Binding Summary.ActionLabel}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                    <Border Classes="surface" Padding="18">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="Comments" />
                                            <TextBlock Classes="muted"
                                                       Text="{Binding CommentCountText}" />
                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasNoComments}"
                                                       Text="No comment has been written for this issue yet." />
                                            <ItemsControl ItemsSource="{Binding Comments}"
                                                          IsVisible="{Binding HasComments}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:IssueCommentViewModel">
                                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Margin="0,0,0,10"
                                                                Padding="14">
                                                            <StackPanel Spacing="8">
                                                                <WrapPanel>
                                                                    <TextBlock Text="{Binding AuthorDisplayName}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TrackyInkBrush}" />
                                                                    <TextBlock Classes="muted"
                                                                               Margin="10,0,0,0"
                                                                               Text="{Binding CreatedText}" />
                                                                    <Border Background="{StaticResource TrackyAccentSoftBrush}"
                                                                            BorderBrush="{StaticResource TrackyAccentBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="999"
                                                                            Margin="10,0,0,0"
                                                                            Padding="7,2">
                                                                        <TextBlock Text="{Binding BodyFormatText}"
                                                                                   Foreground="{StaticResource TrackyAccentBrush}"
                                                                                   FontSize="12"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>
                                                                </WrapPanel>
                                                                <!-- 댓글 역시 같은 렌더링 경로를 타야 Markdown/HTML 포맷 간 표현 차이가 작아진다. -->
                                                                <controls:IssueHtmlPreview HtmlContent="{Binding BodyHtmlDocument}"
                                                                                           FallbackText="{Binding BodyFallbackText}"
                                                                                           PreviewHeight="{Binding BodyPreviewHeight}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Classes="surface"
                                            Padding="18">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="Timeline" />
                                            <TextBlock Classes="muted"
                                                       Text="Creation, comments, state changes, attachments, and reminders are recorded here." />
                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasNoActivity}"
                                                       Text="No activity has been recorded for this issue yet." />
                                            <ItemsControl ItemsSource="{Binding Activity}"
                                                          IsVisible="{Binding HasActivity}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:IssueActivityViewModel">
                                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Margin="0,0,0,10"
                                                                Padding="14">
                                                            <StackPanel Spacing="6">
                                                                <WrapPanel>
                                                                    <Border Background="{StaticResource TrackyAccentSoftBrush}"
                                                                            CornerRadius="999"
                                                                            Padding="8,3">
                                                                        <TextBlock Text="{Binding EventLabel}"
                                                                                   Foreground="{StaticResource TrackyAccentBrush}"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>
                                                                    <TextBlock Classes="muted"
                                                                               Margin="10,4,0,0"
                                                                               Text="{Binding CreatedText}" />
                                                                </WrapPanel>
                                                                <TextBlock Classes="body"
                                                                           Text="{Binding Summary}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                    <Border Classes="surface" Padding="18">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="Relations" />
                                            <TextBlock Classes="muted"
                                                       Text="{Binding RelationCountText}" />
                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasNoRelations}"
                                                       Text="No relation has been linked for this issue." />
                                            <ItemsControl ItemsSource="{Binding Relations}"
                                                          IsVisible="{Binding HasRelations}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:IssueRelationViewModel">
                                                        <TextBlock Classes="body"
                                                                   Margin="0,0,0,8"
                                                                   Text="{Binding TargetText}"
                                                                   TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Classes="surface"
                                            Padding="18">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="Attachments and reminders" />
                                            <TextBlock Classes="muted"
                                                       Text="{Binding AttachmentCountText}" />
                                            <TextBlock Classes="muted"
                                                       Text="{Binding ReminderCountText}" />
                                            <ItemsControl ItemsSource="{Binding Attachments}"
                                                          IsVisible="{Binding HasAttachments}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:IssueAttachmentViewModel">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,0,0,8">
                                                            <TextBlock Classes="body"
                                                                       Text="{Binding FileName}"
                                                                       TextWrapping="Wrap" />
                                                            <Button Grid.Column="1"
                                                                    Classes="secondary"
                                                                    Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).OpenAttachmentCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="Open" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </ScrollViewer>

                <ScrollViewer Grid.Column="1">
                    <Border Classes="surface"
                            Padding="16"
                            IsVisible="{Binding IsIssueEditorVisible}">
                        <StackPanel Spacing="14">
                            <!-- GitHub의 개별 이슈 화면처럼 메타데이터는 상세 화면 안의 보조 컬럼에서 편집한다. -->
                            <TextBlock Classes="section-title" Text="Issue metadata" />

                            <StackPanel x:Name="MetadataTitleSection" Spacing="6">
                                <TextBlock Classes="muted" Text="Title" />
                                <TextBox x:Name="IssueEditTitleBox"
                                         PlaceholderText="Issue title"
                                         Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource TrackyBorderBrush}" />

                            <StackPanel x:Name="MetadataAssigneesSection" Spacing="6">
                                <TextBlock Classes="muted" Text="Assignees" />
                                <TextBox PlaceholderText="Assignee"
                                         Text="{Binding EditAssignee}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource TrackyBorderBrush}" />

                            <StackPanel x:Name="MetadataLabelsSection" Spacing="6">
                                <TextBlock Classes="muted" Text="Labels" />
                                <TextBox PlaceholderText="Labels"
                                         Text="{Binding EditLabels}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource TrackyBorderBrush}" />

                            <StackPanel x:Name="MetadataProjectsSection" Spacing="6">
                                <TextBlock Classes="muted" Text="Projects" />
                                <TextBox PlaceholderText="Project"
                                         Text="{Binding EditProjectName}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource TrackyBorderBrush}" />

                            <StackPanel x:Name="MetadataMilestoneSection" Spacing="6">
                                <TextBlock Classes="muted" Text="Milestone" />
                                <TextBox PlaceholderText="Milestone"
                                         Text="{Binding EditMilestoneName}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource TrackyBorderBrush}" />

                            <StackPanel x:Name="MetadataTypeSection" Spacing="6">
                                <TextBlock Classes="muted" Text="Type" />
                                <TextBox PlaceholderText="Issue type"
                                         Text="{Binding EditIssueTypeName}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource TrackyBorderBrush}" />

                            <StackPanel x:Name="MetadataPrioritySection" Spacing="6">
                                <TextBlock Classes="muted" Text="Priority" />
                                <ComboBox ItemsSource="{Binding AvailablePriorities}"
                                          SelectedItem="{Binding EditPriority}" />
                            </StackPanel>

                            <StackPanel x:Name="MetadataDueDateSection" Spacing="6">
                                <TextBlock Classes="muted" Text="Due date" />
                                <DatePicker SelectedDate="{Binding EditDueDate}" />
                            </StackPanel>

                            <Button x:Name="UpdateIssueButton"
                                    Classes="primary"
                                    Command="{Binding UpdateSelectedIssueCommand}"
                                    Content="Save metadata" />
                            <Button x:Name="DeleteIssueButton"
                                    Classes="secondary"
                                    Command="{Binding DeleteSelectedIssueCommand}"
                                    Content="Delete issue" />
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Grid Grid.Column="0"
              RowDefinitions="Auto,*,Auto"
              RowSpacing="18"
              IsVisible="{Binding IsProjectsViewActive}">
            <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                    BorderBrush="{StaticResource TrackyBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="20,18,20,0">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                    <!-- Tracky는 아직 Git 원격 저장소와 통합하지 않으므로 Watch/Fork/Star 같은 GitHub 원격 액션은 노출하지 않습니다. -->
                    <Grid>
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock x:Name="RepositoryOwnerNameText"
                                       Text="{Binding SelectedRepositoryOwnerName}"
                                       FontSize="20"
                                       Foreground="{StaticResource TrackyAccentBrush}" />
                            <TextBlock Text=" / "
                                       FontSize="20"
                                       Foreground="{StaticResource TrackyMutedInkBrush}" />
                            <TextBlock x:Name="RepositoryNameText"
                                       Text="{Binding SelectedRepositoryName}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TrackyAccentBrush}" />
                            <Border x:Name="RepositoryVisibilityBadge"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource TrackyBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Margin="10,2,0,0"
                                    Padding="7,1">
                                <TextBlock Classes="muted"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="Local" />
                            </Border>
                        </WrapPanel>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Spacing="2">
                        <Button Classes="github-tab" Content="Code" IsEnabled="False" />
                        <Button x:Name="RepositoryIssuesTabButton"
                                Classes="github-tab"
                                Classes.active="{Binding IsRepositoryIssuesTabActive}"
                                Command="{Binding ShowRepositoryIssuesCommand}"
                                Content="{Binding RepositoryIssueCountText, StringFormat='Issues  {0}'}" />
                        <Button Classes="github-tab" Content="Pull requests" IsEnabled="False" />
                        <Button x:Name="RepositoryDiscussionsTabButton"
                                Classes="github-tab"
                                Content="Discussions"
                                IsEnabled="False" />
                        <Button Classes="github-tab" Content="Actions" IsEnabled="False" />
                        <Button x:Name="RepositoryProjectsTabButton"
                                Classes="github-tab"
                                Classes.active="{Binding IsRepositoryProjectsTabActive}"
                                Command="{Binding ShowRepositoryProjectsCommand}"
                                Content="Projects" />
                        <Button x:Name="RepositorySecurityTabButton"
                                Classes="github-tab"
                                Content="Security and quality"
                                IsEnabled="False" />
                        <Button Classes="github-tab" Content="Insights" IsEnabled="False" />
                    </StackPanel>

                    <!-- GitHub 저장소 화면처럼 별도 대시보드 카드를 두지 않고, 로컬 Issue Repository 전환만 낮은 헤더 행으로 유지합니다. -->
                    <ListBox x:Name="RepositoryListBox"
                             Grid.Row="2"
                             ItemsSource="{Binding Projects}"
                             SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProjectSummaryViewModel">
                                <Border Background="{StaticResource TrackySurfaceBrush}"
                                        BorderBrush="{StaticResource TrackyBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="260"
                                        MaxWidth="340"
                                        Padding="12,10">
                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TrackyInkBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Classes="muted"
                                                       Text="{Binding IssueCountText}" />
                                        </Grid>
                                        <TextBlock Grid.Row="1"
                                                   Classes="muted"
                                                   Text="{Binding UpdatedText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Row="1" Classes="surface" Padding="0">
                <Grid RowDefinitions="Auto,Auto,*">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                          ColumnSpacing="8"
                          Margin="16,16,16,12">
                        <TextBox x:Name="RepositoryIssueSearchBox"
                                 Classes="search-box"
                                 PlaceholderText="is:issue state:open"
                                 Text="{Binding RepositoryIssueSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 IsVisible="{Binding IsRepositoryIssuesTabActive}" />
                        <Button x:Name="RepositoryLabelsButton"
                                Grid.Column="1"
                                Classes="secondary"
                                Content="Labels"
                                IsVisible="{Binding IsRepositoryIssuesTabActive}" />
                        <Button x:Name="RepositoryMilestonesButton"
                                Grid.Column="2"
                                Classes="secondary"
                                Command="{Binding ShowRepositoryMilestonesCommand}"
                                Content="Milestones"
                                IsVisible="{Binding IsRepositoryIssuesTabActive}" />
                        <Button x:Name="RepositoryNewIssueButton"
                                Grid.Column="3"
                                Classes="primary"
                                Command="{Binding PrepareNewIssueCommand}"
                                Content="New issue"
                                IsVisible="{Binding IsRepositoryIssuesTabActive}" />

                        <!-- GitHub Milestones 목록의 상단 상태/정렬 행을 따라 Open, Closed, Sort를 먼저 노출합니다. -->
                        <Grid Grid.ColumnSpan="4"
                              ColumnDefinitions="Auto,Auto,*,Auto"
                              ColumnSpacing="16"
                              IsVisible="{Binding IsRepositoryMilestonesTabActive}">
                            <TextBlock x:Name="RepositoryMilestonesOpenText"
                                       Classes="body"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="{Binding RepositoryMilestoneCountText, StringFormat='Open {0}'}" />
                            <TextBlock x:Name="RepositoryMilestonesClosedText"
                                       Grid.Column="1"
                                       Classes="muted"
                                       VerticalAlignment="Center"
                                       Text="Closed 0" />
                            <Button x:Name="RepositoryMilestonesSortButton"
                                    Grid.Column="3"
                                    Classes="secondary"
                                    Content="Sort" />
                        </Grid>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="0,1,0,1"
                            Padding="16,10"
                            IsVisible="{Binding IsRepositoryIssuesTabActive}">
                        <Grid ColumnDefinitions="Auto,Auto,*"
                              ColumnSpacing="16">
                            <TextBlock x:Name="RepositoryOpenIssuesText"
                                       Classes="body"
                                       FontWeight="SemiBold"
                                       Text="{Binding RepositoryOpenIssuesText}" />
                            <TextBlock x:Name="RepositoryClosedIssuesText"
                                       Grid.Column="1"
                                       Classes="muted"
                                       Text="{Binding RepositoryClosedIssuesText}" />
                        </Grid>
                    </Border>

                    <ListBox x:Name="RepositoryIssuesListBox"
                             Grid.Row="2"
                             ItemsSource="{Binding RepositoryIssues}"
                             SelectedItem="{Binding SelectedIssue, Mode=TwoWay}"
                             IsVisible="{Binding IsRepositoryIssuesTabActive}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:IssueCardViewModel">
                                <Border Classes="issue-row"
                                        BorderBrush="{Binding CardBorderBrush}">
                                    <Grid ColumnDefinitions="28,*,Auto" ColumnSpacing="12">
                                        <Border Width="20"
                                                Height="20"
                                                CornerRadius="10"
                                                Background="{Binding StateIconBackground}"
                                                VerticalAlignment="Top">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding StateIconForeground}"
                                                       Text="{Binding StateIconText}" />
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <WrapPanel>
                                                <TextBlock Classes="issue-title"
                                                           Margin="0,0,8,4"
                                                           Text="{Binding Title}"
                                                           TextWrapping="Wrap" />
                                                <Border Background="{Binding PriorityBadgeBackground}"
                                                        CornerRadius="999"
                                                        Margin="0,0,6,4"
                                                        Padding="8,2">
                                                    <TextBlock FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding PriorityBadgeForeground}"
                                                               Text="{Binding PriorityText}" />
                                                </Border>
                                                <ItemsControl ItemsSource="{Binding LabelChips}"
                                                              IsVisible="{Binding HasLabels}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:LabelChipViewModel">
                                                            <Border Classes="label-chip"
                                                                    Background="{Binding Background}"
                                                                    BorderBrush="{Binding BorderBrush}">
                                                                <TextBlock Classes="label-chip-text"
                                                                           Text="{Binding Name}"
                                                                           Foreground="{Binding Foreground}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </WrapPanel>

                                            <TextBlock Classes="muted"
                                                       Text="{Binding GitHubListMetaText}" />
                                            <WrapPanel>
                                                <TextBlock Classes="muted"
                                                           Margin="0,0,12,0"
                                                           Text="{Binding GitHubListSecondaryText}" />
                                                <Border Background="{Binding DueBadgeBackground}"
                                                        CornerRadius="999"
                                                        Padding="8,2"
                                                        IsVisible="{Binding HasDueDate}">
                                                    <TextBlock FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding DueBadgeForeground}"
                                                               Text="{Binding DueText}" />
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="12"
                                                    VerticalAlignment="Top">
                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasComments}"
                                                       Text="{Binding CommentBadgeText, StringFormat='Comments {0}'}" />
                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasAttachments}"
                                                       Text="{Binding AttachmentsText}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ScrollViewer Grid.Row="2"
                                  IsVisible="{Binding IsRepositoryMilestonesTabActive}">
                        <ItemsControl x:Name="RepositoryMilestonesPanel"
                                      ItemsSource="{Binding RepositoryMilestones}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RepositoryMilestoneViewModel">
                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,0,0,10"
                                            Padding="16">
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TrackyInkBrush}" />
                                                    <TextBlock Classes="muted"
                                                               Text="{Binding DueText}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Classes="muted"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding IssueCountText}" />
                                            </Grid>

                                            <ProgressBar Grid.Row="1"
                                                         Minimum="0"
                                                         Maximum="100"
                                                         Height="8"
                                                         Value="{Binding CompletionPercent}" />

                                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                                <TextBlock Classes="muted"
                                                           Text="{Binding ProgressText}" />
                                                <TextBlock Grid.Column="1"
                                                           Classes="muted"
                                                           Text="{Binding CompletionText}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ContentControl x:Name="RepositoryProjectsContent"
                                    Grid.Row="2"
                                    IsVisible="{Binding IsRepositoryProjectsTabActive}">
                        <Grid RowDefinitions="Auto,*" RowSpacing="14">
                            <Grid ColumnDefinitions="240,150,150,*,Auto"
                                  ColumnSpacing="8">
                                <TextBox x:Name="RepositoryProjectsSearchBox"
                                         Classes="search-box"
                                         PlaceholderText="Search all projects"
                                         Text="{Binding ProjectFilterText, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding AvailableProjectSortFields}"
                                          SelectedItem="{Binding ProjectSortText}" />
                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding AvailableProjectGroupFields}"
                                          SelectedItem="{Binding ProjectGroupByText}" />
                                <TextBlock x:Name="RepositoryProjectsResultsText"
                                           Grid.Column="3"
                                           Classes="muted"
                                           VerticalAlignment="Center"
                                           Text="{Binding RepositoryProjectsResultsText}" />
                                <StackPanel Grid.Column="4"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Classes="scope-chip"
                                            Classes.active="{Binding IsProjectBoardViewActive}"
                                            Command="{Binding ShowProjectBoardCommand}"
                                            Content="Board" />
                                    <Button Classes="scope-chip"
                                            Classes.active="{Binding IsProjectTableViewActive}"
                                            Command="{Binding ShowProjectTableCommand}"
                                            Content="Table" />
                                    <Button Classes="scope-chip"
                                            Classes.active="{Binding IsProjectCalendarViewActive}"
                                            Command="{Binding ShowProjectCalendarCommand}"
                                            Content="Calendar" />
                                    <Button Classes="scope-chip"
                                            Classes.active="{Binding IsProjectTimelineViewActive}"
                                            Command="{Binding ShowProjectTimelineCommand}"
                                            Content="Timeline" />
                                </StackPanel>
                            </Grid>

                    <ScrollViewer Grid.Row="1" IsVisible="{Binding IsProjectBoardViewActive}">
                        <ItemsControl ItemsSource="{Binding ProjectBoardColumns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="14" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ProjectBoardColumnViewModel">
                                    <Border Width="282"
                                            Background="{StaticResource TrackySurfaceStrongBrush}"
                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,0,14,0"
                                            Padding="16">
                                        <Grid RowDefinitions="Auto,*" RowSpacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TrackyInkBrush}" />
                                                <TextBlock Classes="muted" Text="{Binding CountText}" />
                                            </StackPanel>

                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:ProjectIssueItemViewModel">
                                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Margin="0,0,0,10"
                                                                Padding="14">
                                                            <StackPanel Spacing="10">
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TrackyInkBrush}"
                                                                           TextWrapping="Wrap" />
                                                                <WrapPanel>
                                                                    <TextBlock Classes="mono"
                                                                               Margin="0,0,10,0"
                                                                               Text="{Binding IssueNumberText}" />
                                                                    <TextBlock Classes="muted"
                                                                               Margin="0,0,10,0"
                                                                               Text="{Binding AssigneeText}" />
                                                                    <TextBlock Classes="muted"
                                                                               Text="{Binding DueText}" />
                                                                </WrapPanel>
                                                                <Border Background="{Binding PriorityBadgeBackground}"
                                                                        CornerRadius="999"
                                                                        HorizontalAlignment="Left"
                                                                        Padding="9,4">
                                                                    <TextBlock Text="{Binding PriorityText}"
                                                                               Foreground="{Binding PriorityBadgeForeground}"
                                                                               FontWeight="SemiBold" />
                                                                </Border>
                                                                <TextBlock Classes="muted"
                                                                           Text="{Binding CustomFieldSummaryText}"
                                                                           TextWrapping="Wrap" />
                                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                                    <Button Classes="secondary"
                                                                            Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).MoveProjectItemBackwardCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            Content="{Binding MoveBackwardLabel}" />
                                                                    <Button Grid.Column="1"
                                                                            Classes="secondary"
                                                                            Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).MoveProjectItemForwardCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            Content="{Binding MoveForwardLabel}" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ScrollViewer Grid.Row="1" IsVisible="{Binding IsProjectTableViewActive}">
                        <ItemsControl ItemsSource="{Binding ProjectTableGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ProjectIssueGroupViewModel">
                                    <StackPanel Spacing="8" Margin="0,0,0,18">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Classes="section-title" Text="{Binding Name}" />
                                            <TextBlock Grid.Column="1" Classes="muted" Text="{Binding CountText}" />
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ProjectIssueItemViewModel">
                                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Margin="0,0,0,10"
                                                            Padding="14">
                                                        <Grid ColumnDefinitions="90,*,120,130,110,180" ColumnSpacing="12">
                                                            <TextBlock Classes="mono" Text="{Binding IssueNumberText}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Title}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TrackyInkBrush}" />
                                                            <TextBlock Grid.Column="2" Classes="muted" Text="{Binding BoardColumn}" />
                                                            <TextBlock Grid.Column="3" Classes="muted" Text="{Binding AssigneeText}" />
                                                            <TextBlock Grid.Column="4" Classes="muted" Text="{Binding DueText}" />
                                                            <TextBlock Grid.Column="5"
                                                                       Classes="muted"
                                                                       Text="{Binding CustomFieldSummaryText}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ScrollViewer Grid.Row="1" IsVisible="{Binding IsProjectCalendarViewActive}">
                        <ItemsControl ItemsSource="{Binding ProjectCalendarGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ProjectIssueGroupViewModel">
                                    <StackPanel Spacing="8" Margin="0,0,0,18">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Classes="section-title" Text="{Binding Name}" />
                                            <TextBlock Grid.Column="1" Classes="muted" Text="{Binding CountText}" />
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ProjectIssueItemViewModel">
                                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Margin="0,0,0,10"
                                                            Padding="14">
                                                        <Grid ColumnDefinitions="140,*,140" ColumnSpacing="12">
                                                            <TextBlock Classes="body" Text="{Binding DueText}" />
                                                            <StackPanel Grid.Column="1" Spacing="4">
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TrackyInkBrush}" />
                                                                <TextBlock Classes="mono" Text="{Binding IssueNumberText}" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2" Classes="muted" Text="{Binding BoardColumn}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ScrollViewer Grid.Row="1" IsVisible="{Binding IsProjectTimelineViewActive}">
                        <ItemsControl ItemsSource="{Binding ProjectTimelineGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ProjectIssueGroupViewModel">
                                    <StackPanel Spacing="8" Margin="0,0,0,18">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Classes="section-title" Text="{Binding Name}" />
                                            <TextBlock Grid.Column="1" Classes="muted" Text="{Binding CountText}" />
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ProjectIssueItemViewModel">
                                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Margin="0,0,0,10"
                                                            Padding="14">
                                                        <Grid ColumnDefinitions="170,*,120" ColumnSpacing="12">
                                                            <TextBlock Classes="body" Text="{Binding DueText}" />
                                                            <StackPanel Grid.Column="1" Spacing="4">
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TrackyInkBrush}" />
                                                                <TextBlock Classes="muted" Text="{Binding StateText}" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2" Classes="mono" Text="{Binding IssueNumberText}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                        </Grid>
                    </ContentControl>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2"
                       Classes="muted"
                       Text="{Binding ProjectStatusMessage}"
                       TextWrapping="Wrap" />
        </Grid>

        <Border Grid.Column="0" Classes="surface" Padding="20" IsVisible="False">
            <ScrollViewer>
                <StackPanel Spacing="18">
                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsProjectsViewActive}">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section-title" Text="New Project" />
                            <TextBlock Classes="muted"
                                       Text="Create a project shell first, then assign issues to it from quick capture or issue editing." />

                            <TextBlock Classes="muted" Text="Name" />
                            <TextBox x:Name="NewProjectNameBox"
                                     PlaceholderText="Tracky Phase 2"
                                     Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Classes="muted" Text="Description" />
                            <TextBox AcceptsReturn="True"
                                     Height="90"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     PlaceholderText="Project board, table, calendar, and timeline scope."
                                     Text="{Binding NewProjectDescription}" />

                            <Button x:Name="CreateProjectButton"
                                    Classes="primary"
                                    Command="{Binding CreateProjectCommand}"
                                    Content="Create project" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsProjectsViewActive}">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section-title" Text="Field Values" />
                            <TextBlock Classes="muted"
                                       Text="Select a project item and custom field, then save the value used by filters such as impact:high." />

                            <TextBlock Classes="muted" Text="Project item" />
                            <ComboBox x:Name="ProjectFieldItemComboBox"
                                      ItemsSource="{Binding ProjectTableItems}"
                                      SelectedItem="{Binding SelectedProjectItemForFields}" />

                            <TextBlock Classes="muted" Text="Field" />
                            <ComboBox x:Name="ProjectFieldComboBox"
                                      ItemsSource="{Binding ProjectCustomFields}"
                                      SelectedItem="{Binding SelectedProjectCustomField}" />

                            <TextBlock Classes="muted" Text="Value" />
                            <TextBox x:Name="ProjectFieldValueBox"
                                     PlaceholderText="High"
                                     Text="{Binding DraftCustomFieldValue, UpdateSourceTrigger=PropertyChanged}" />

                            <Button x:Name="SaveProjectCustomFieldValueButton"
                                    Classes="secondary"
                                    Command="{Binding SaveProjectCustomFieldValueCommand}"
                                    Content="Save field value" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsProjectsViewActive}">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section-title" Text="Custom Fields" />

                            <ItemsControl ItemsSource="{Binding ProjectCustomFields}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProjectCustomFieldViewModel">
                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Margin="0,0,0,8"
                                                Padding="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TrackyInkBrush}" />
                                                <WrapPanel>
                                                    <TextBlock Classes="muted"
                                                               Margin="0,0,12,0"
                                                               Text="{Binding FieldTypeText}" />
                                                    <TextBlock Classes="muted" Text="{Binding OptionsText}" />
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Classes="muted" Text="Field name" />
                            <TextBox PlaceholderText="Impact"
                                     Text="{Binding DraftCustomFieldName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Classes="muted" Text="Type" />
                            <ComboBox ItemsSource="{Binding AvailableProjectCustomFieldTypes}"
                                      SelectedItem="{Binding DraftCustomFieldType}" />

                            <TextBlock Classes="muted" Text="Options" />
                            <TextBox PlaceholderText="Low, Medium, High"
                                     Text="{Binding DraftCustomFieldOptions}" />

                            <Button x:Name="AddProjectCustomFieldButton"
                                    Classes="secondary"
                                    Command="{Binding AddProjectCustomFieldCommand}"
                                    Content="Add custom field" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsProjectsViewActive}">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section-title" Text="Saved Views" />

                            <ItemsControl ItemsSource="{Binding ProjectSavedViews}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProjectSavedViewViewModel">
                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Margin="0,0,0,8"
                                                Padding="12">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TrackyInkBrush}" />
                                                    <WrapPanel>
                                                        <TextBlock Classes="muted"
                                                                   Margin="0,0,12,0"
                                                                   Text="{Binding ViewModeText}" />
                                                        <TextBlock Classes="muted"
                                                                   Margin="0,0,12,0"
                                                                   Text="{Binding FilterText}" />
                                                        <TextBlock Classes="muted"
                                                                   Margin="0,0,12,0"
                                                                   Text="{Binding SortText}" />
                                                        <TextBlock Classes="muted" Text="{Binding GroupByText}" />
                                                    </WrapPanel>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Classes="secondary"
                                                        Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).ApplyProjectSavedViewCommand}"
                                                        CommandParameter="{Binding}"
                                                        Content="Apply" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Classes="muted" Text="View name" />
                            <TextBox PlaceholderText="High impact board"
                                     Text="{Binding DraftSavedViewName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Classes="muted" Text="Mode" />
                            <ComboBox ItemsSource="{Binding AvailableProjectViewModes}"
                                      SelectedItem="{Binding DraftSavedViewMode}" />

                            <TextBlock Classes="muted" Text="Filter" />
                            <TextBox PlaceholderText="is:open priority:high"
                                     Text="{Binding DraftSavedViewFilter}" />

                            <TextBlock Classes="muted" Text="Sort" />
                            <ComboBox ItemsSource="{Binding AvailableProjectSortFields}"
                                      SelectedItem="{Binding DraftSavedViewSort}" />

                            <TextBlock Classes="muted" Text="Group" />
                            <ComboBox ItemsSource="{Binding AvailableProjectGroupFields}"
                                      SelectedItem="{Binding DraftSavedViewGroup}" />

                            <Button x:Name="AddProjectSavedViewButton"
                                    Classes="secondary"
                                    Command="{Binding AddProjectSavedViewCommand}"
                                    Content="Add saved view" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsIssuesViewActive}">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section-title" Text="Reminders" />

                            <TextBlock Classes="muted"
                                       IsVisible="{Binding HasNoWorkspaceReminders}"
                                       Text="No active reminders." />

                            <ItemsControl ItemsSource="{Binding WorkspaceReminders}"
                                          IsVisible="{Binding HasWorkspaceReminders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:IssueReminderViewModel">
                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Margin="0,0,0,8"
                                                Padding="12">
                                            <StackPanel Spacing="6">
                                                <WrapPanel>
                                                    <Border Background="{Binding StatusBadgeBackground}"
                                                            CornerRadius="999"
                                                            Margin="0,0,8,0"
                                                            Padding="8,3">
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   Foreground="{Binding StatusBadgeForeground}"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                    <TextBlock Classes="muted"
                                                               Margin="0,4,0,0"
                                                               Text="{Binding RemindAtText}" />
                                                </WrapPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TrackyInkBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Classes="muted"
                                                           Text="{Binding Note}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Classes="muted" Text="Title" />
                            <TextBox PlaceholderText="Follow up on selected issue"
                                     Text="{Binding DraftReminderTitle, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Classes="muted" Text="Note" />
                            <TextBox PlaceholderText="What should be remembered?"
                                     Text="{Binding DraftReminderNote}" />

                            <TextBlock Classes="muted" Text="Remind at" />
                            <DatePicker SelectedDate="{Binding DraftReminderAt}" />

                            <Button x:Name="ScheduleReminderButton"
                                    Classes="secondary"
                                    Command="{Binding ScheduleReminderCommand}"
                                    Content="Schedule reminder" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsIssuesViewActive}">
                        <StackPanel Spacing="14">
                            <!-- 저장 검색은 현재 필터 문자열을 이름과 함께 보존해 반복적인 triage 흐름을 빠르게 재사용한다. -->
                            <TextBlock Classes="section-title" Text="Saved Searches" />

                            <TextBlock Classes="muted"
                                       IsVisible="{Binding HasNoSavedIssueSearches}"
                                       Text="No saved search has been stored." />

                            <ItemsControl ItemsSource="{Binding SavedIssueSearches}"
                                          IsVisible="{Binding HasSavedIssueSearches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SavedIssueSearchViewModel">
                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Margin="0,0,0,8"
                                                Padding="12">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TrackyInkBrush}" />
                                                    <TextBlock Classes="muted"
                                                               Text="{Binding QueryText}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Classes="secondary"
                                                        Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).ApplySavedIssueSearchCommand}"
                                                        CommandParameter="{Binding}"
                                                        Content="Apply" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Classes="muted" Text="Search name" />
                            <TextBox PlaceholderText="Open desktop work"
                                     Text="{Binding DraftSavedIssueSearchName, UpdateSourceTrigger=PropertyChanged}" />

                            <CheckBox Content="Pinned"
                                      IsChecked="{Binding DraftSavedIssueSearchPinned}" />

                            <Button x:Name="LegacySaveIssueSearchButton"
                                    Classes="secondary"
                                    Command="{Binding SaveIssueSearchCommand}"
                                    Content="Save current search" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsIssuesViewActive}">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section-title" Text="Export" />

                            <ItemsControl ItemsSource="{Binding ExportPresets}"
                                          IsVisible="{Binding HasExportPresets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ExportPresetViewModel">
                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Margin="0,0,0,8"
                                                Padding="12">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TrackyInkBrush}" />
                                                    <TextBlock Classes="muted"
                                                               Text="{Binding Summary}" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Classes="secondary"
                                                        Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).ApplyExportPresetCommand}"
                                                        CommandParameter="{Binding}"
                                                        Content="Apply" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Classes="muted" Text="Scope" />
                            <ComboBox ItemsSource="{Binding AvailableExportScopes}"
                                      SelectedItem="{Binding DraftExportScope}" />

                            <TextBlock Classes="muted" Text="Format" />
                            <ComboBox ItemsSource="{Binding AvailableExportFormats}"
                                      SelectedItem="{Binding DraftExportFormat}" />

                            <TextBlock Classes="muted" Text="Body" />
                            <ComboBox ItemsSource="{Binding AvailableExportBodyFormats}"
                                      SelectedItem="{Binding DraftExportBodyFormat}" />

                            <CheckBox Content="Comments"
                                      IsChecked="{Binding DraftExportIncludeComments}" />
                            <CheckBox Content="Activity"
                                      IsChecked="{Binding DraftExportIncludeActivity}" />
                            <CheckBox Content="Attachments"
                                      IsChecked="{Binding DraftExportIncludeAttachments}" />
                            <CheckBox Content="Closed issues"
                                      IsChecked="{Binding DraftExportIncludeClosedIssues}" />

                            <Button x:Name="LegacyExportSelectionButton"
                                    Classes="primary"
                                    Command="{Binding ExportSelectionCommand}"
                                    Content="Export selection" />

                            <TextBlock Classes="muted" Text="Preset name" />
                            <TextBox PlaceholderText="Weekly Markdown handoff"
                                     Text="{Binding ExportPresetName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button x:Name="LegacySaveExportPresetButton"
                                    Classes="secondary"
                                    Command="{Binding SaveExportPresetCommand}"
                                    Content="Save export preset" />
                            <TextBlock Classes="mono"
                                       Text="{Binding LastExportPath}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsIssuesViewActive}">
                        <StackPanel Spacing="14">
                            <!-- 환경설정은 DB에 저장되는 워크스페이스 단위 선호값을 직접 편집하게 해 Phase3 개인화 요구를 검증한다. -->
                            <TextBlock Classes="section-title" Text="Preferences" />

                            <TextBlock Classes="muted" Text="Theme" />
                            <ComboBox ItemsSource="{Binding AvailableThemePreferences}"
                                      SelectedItem="{Binding SelectedThemePreference}" />

                            <CheckBox Content="Compact density"
                                      IsChecked="{Binding CompactDensityPreference}" />

                            <TextBlock Classes="muted" Text="Shortcut profile" />
                            <TextBox PlaceholderText="Default"
                                     Text="{Binding ShortcutProfilePreference}" />

                            <Button x:Name="LegacySavePreferencesButton"
                                    Classes="secondary"
                                    Command="{Binding SavePreferencesCommand}"
                                    Content="Save preferences" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsQuickCaptureVisible}">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section-title" Text="New issue" />

                            <TextBlock Classes="muted" Text="Title" />
                            <TextBox x:Name="LegacyQuickCaptureTitleBox"
                                     PlaceholderText="Ship workspace bootstrap and issue shell"
                                     Text="{Binding DraftTitle}" />

                            <TextBlock Classes="muted" Text="Assignee" />
                            <TextBox PlaceholderText="Dabin"
                                     Text="{Binding DraftAssignee}" />

                            <TextBlock Classes="muted" Text="Priority" />
                            <ComboBox ItemsSource="{Binding AvailablePriorities}"
                                      SelectedItem="{Binding DraftPriority}" />

                            <TextBlock Classes="muted" Text="Due date" />
                            <DatePicker SelectedDate="{Binding DraftDueDate}" />

                            <TextBlock Classes="muted" Text="Project" />
                            <TextBox PlaceholderText="Tracky Foundation"
                                     Text="{Binding DraftProjectName}" />

                            <!-- Phase3 메타데이터는 생성 시점부터 저장해 검색, 프로젝트 동기화, 내보내기에서 같은 값을 사용한다. -->
                            <TextBlock Classes="muted" Text="Milestone" />
                            <TextBox PlaceholderText="MVP Readiness"
                                     Text="{Binding DraftMilestoneName}" />

                            <TextBlock Classes="muted" Text="Issue type" />
                            <TextBox PlaceholderText="Task"
                                     Text="{Binding DraftIssueTypeName}" />

                            <TextBlock Classes="muted" Text="Labels" />
                            <TextBox PlaceholderText="foundation, desktop, ux"
                                     Text="{Binding DraftLabels}" />

                            <Button x:Name="LegacyCreateIssueButton"
                                    Classes="primary"
                                    Command="{Binding CreateIssueCommand}"
                                    Content="Submit new issue" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsIssueEditorVisible}">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section-title" Text="Issue sidebar" />

                            <TextBlock Classes="muted" Text="Title" />
                            <TextBox x:Name="LegacyIssueEditTitleBox"
                                     PlaceholderText="Issue title"
                                     Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Classes="muted" Text="Description" />
                            <TextBox x:Name="LegacyIssueEditDescriptionBox"
                                     AcceptsReturn="True"
                                     Height="120"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     PlaceholderText="Write the issue body in Markdown."
                                     Text="{Binding EditDescription}" />

                            <TextBlock Classes="muted" Text="Assignee" />
                            <TextBox PlaceholderText="Dabin"
                                     Text="{Binding EditAssignee}" />

                            <TextBlock Classes="muted" Text="Priority" />
                            <ComboBox ItemsSource="{Binding AvailablePriorities}"
                                      SelectedItem="{Binding EditPriority}" />

                            <TextBlock Classes="muted" Text="Due date" />
                            <DatePicker SelectedDate="{Binding EditDueDate}" />

                            <TextBlock Classes="muted" Text="Project" />
                            <TextBox PlaceholderText="Tracky Foundation"
                                     Text="{Binding EditProjectName}" />

                            <!-- 편집 폼도 생성 폼과 같은 Phase3 메타데이터를 다뤄 저장 후 상세/필터 상태가 어긋나지 않게 한다. -->
                            <TextBlock Classes="muted" Text="Milestone" />
                            <TextBox PlaceholderText="MVP Readiness"
                                     Text="{Binding EditMilestoneName}" />

                            <TextBlock Classes="muted" Text="Issue type" />
                            <TextBox PlaceholderText="Bug"
                                     Text="{Binding EditIssueTypeName}" />

                            <TextBlock Classes="muted" Text="Labels" />
                            <TextBox PlaceholderText="foundation, desktop, ux"
                                     Text="{Binding EditLabels}" />

                            <TextBlock Classes="muted"
                                       IsVisible="{Binding CanChooseCloseReason}"
                                       Text="Close reason" />
                            <ComboBox x:Name="LegacyCloseReasonComboBox"
                                      ItemsSource="{Binding AvailableCloseReasons}"
                                      SelectedItem="{Binding SelectedCloseReason}"
                                      IsVisible="{Binding CanChooseCloseReason}" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button x:Name="LegacyUpdateIssueButton"
                                        Classes="primary"
                                        Command="{Binding UpdateSelectedIssueCommand}"
                                        Content="Save changes" />
                                <Button x:Name="LegacyDeleteIssueButton"
                                        Grid.Column="1"
                                        Classes="secondary"
                                        Command="{Binding DeleteSelectedIssueCommand}"
                                        Content="Delete issue" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsIssuesViewActive}">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="section-title" Text="Timeline status" />
                            <TextBlock x:Name="LegacyDetailStatusMessageText"
                                       Classes="muted"
                                       Text="{Binding DetailStatusMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                            BorderBrush="{StaticResource TrackyBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            IsVisible="{Binding IsIssueDetailPlaceholderVisible}">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="section-title" Text="No issue selected" />
                            <TextBlock Classes="muted"
                                       Text="Choose an issue row to inspect its body, timeline, comments, and attachments." />
                        </StackPanel>
                    </Border>

                    <ContentControl x:Name="LegacySelectedIssueDetailContent"
                                    Content="{Binding SelectedIssueDetail}"
                                    IsVisible="False">
                        <ContentControl.ContentTemplate>
                            <DataTemplate x:DataType="vm:IssueDetailViewModel">
                                <StackPanel Spacing="18">
                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18">
                                        <StackPanel Spacing="14">
                                            <TextBlock Classes="section-title" Text="Issue Details" />

                                            <StackPanel Spacing="6">
                                                <TextBlock Text="{Binding Summary.Title}"
                                                           FontSize="22"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TrackyInkBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Classes="mono" Text="{Binding Summary.NumberText}" />
                                            </StackPanel>

                                            <WrapPanel>
                                                <Border Background="{Binding Summary.StateBadgeBackground}"
                                                        CornerRadius="999"
                                                        Margin="0,0,8,8"
                                                        Padding="10,5">
                                                    <TextBlock Text="{Binding Summary.StateText}"
                                                               Foreground="{Binding Summary.StateBadgeForeground}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                                <Border Background="{Binding Summary.PriorityBadgeBackground}"
                                                        CornerRadius="999"
                                                        Margin="0,0,8,8"
                                                        Padding="10,5">
                                                    <TextBlock Text="{Binding Summary.PriorityText}"
                                                               Foreground="{Binding Summary.PriorityBadgeForeground}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                                <Border Background="{Binding Summary.DueBadgeBackground}"
                                                        CornerRadius="999"
                                                        Margin="0,0,8,8"
                                                        Padding="10,5"
                                                        IsVisible="{Binding Summary.HasDueDate}">
                                                    <TextBlock Text="{Binding Summary.DueText}"
                                                               Foreground="{Binding Summary.DueBadgeForeground}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </WrapPanel>

                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="muted" Text="State detail" />
                                                <TextBlock Grid.Row="0" Grid.Column="1" Classes="body" Text="{Binding Summary.StateDetailText}" />

                                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="muted" Text="Assignee" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Classes="body" Text="{Binding Summary.AssigneeText}" />

                                                <TextBlock Grid.Row="2" Grid.Column="0" Classes="muted" Text="Project" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Classes="body" Text="{Binding Summary.ProjectText}" />

                                                <TextBlock Grid.Row="3" Grid.Column="0" Classes="muted" Text="Milestone" />
                                                <TextBlock Grid.Row="3" Grid.Column="1" Classes="body" Text="{Binding Summary.MilestoneText}" />

                                                <TextBlock Grid.Row="4" Grid.Column="0" Classes="muted" Text="Issue type" />
                                                <TextBlock Grid.Row="4" Grid.Column="1" Classes="body" Text="{Binding Summary.IssueTypeText}" />

                                                <TextBlock Grid.Row="5" Grid.Column="0" Classes="muted" Text="Comments" />
                                                <TextBlock Grid.Row="5" Grid.Column="1" Classes="body" Text="{Binding CommentCountText}" />

                                                <TextBlock Grid.Row="6" Grid.Column="0" Classes="muted" Text="Attachments" />
                                                <TextBlock Grid.Row="6" Grid.Column="1" Classes="body" Text="{Binding AttachmentCountText}" />
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Summary.LabelChips}"
                                                          IsVisible="{Binding Summary.HasLabels}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:LabelChipViewModel">
                                                        <Border Classes="label-chip"
                                                                Background="{Binding Background}"
                                                                BorderBrush="{Binding BorderBrush}"
                                                                Margin="0,0,8,8"
                                                                Padding="10,3">
                                                            <TextBlock Classes="label-chip-text"
                                                                       Text="{Binding Name}"
                                                                       Foreground="{Binding Foreground}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Classes="muted" Text="{Binding Summary.UpdatedText}" />

                                            <Button Classes="secondary"
                                                    Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).ToggleSelectedIssueStateCommand}"
                                                    Content="{Binding Summary.ActionLabel}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="Description" />
                                            <TextBlock Classes="body"
                                                       Text="{Binding DescriptionText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18">
                                        <StackPanel Spacing="12">
                                            <!-- 관계는 Phase3의 의존성/중복/부모-자식 추적 기능이므로 상세 화면에서 바로 추가하고 확인한다. -->
                                            <TextBlock Classes="section-title" Text="Relations" />
                                            <TextBlock Classes="muted"
                                                       Text="{Binding RelationCountText}" />

                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasNoRelations}"
                                                       Text="No relation has been linked for this issue." />

                                            <ItemsControl ItemsSource="{Binding Relations}"
                                                          IsVisible="{Binding HasRelations}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:IssueRelationViewModel">
                                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Margin="0,0,0,10"
                                                                Padding="14">
                                                            <StackPanel Spacing="6">
                                                                <WrapPanel>
                                                                    <Border Background="{StaticResource TrackyAccentSoftBrush}"
                                                                            CornerRadius="999"
                                                                            Margin="0,0,8,0"
                                                                            Padding="8,3">
                                                                        <TextBlock Text="{Binding RelationTypeText}"
                                                                                   Foreground="{StaticResource TrackyAccentBrush}"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>
                                                                    <TextBlock Classes="muted"
                                                                               Margin="0,4,0,0"
                                                                               Text="{Binding CreatedText}" />
                                                                </WrapPanel>
                                                                <TextBlock Text="{Binding TargetText}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TrackyInkBrush}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Grid ColumnDefinitions="*,150" ColumnSpacing="10">
                                                <TextBox PlaceholderText="Target issue number"
                                                         Text="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).DraftRelationTargetIssueNumber}" />
                                                <ComboBox Grid.Column="1"
                                                          ItemsSource="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).AvailableIssueRelationTypes}"
                                                          SelectedItem="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).DraftRelationType}" />
                                            </Grid>

                                            <Button Classes="secondary"
                                                    Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).AddIssueRelationCommand}"
                                                    Content="Add relation" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="Add Comment" />
                                            <TextBlock Classes="muted"
                                                       Text="Use this composer to record notes directly into the local issue timeline." />

                                            <TextBlock Classes="muted" Text="Author" />
                                            <TextBox PlaceholderText="Dabin"
                                                     Text="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).DraftCommentAuthor}" />

                                            <TextBlock Classes="muted" Text="Comment" />
                                            <TextBox x:Name="CommentBodyBox"
                                                     AcceptsReturn="True"
                                                     Height="120"
                                                     TextWrapping="Wrap"
                                                     VerticalContentAlignment="Top"
                                                     PlaceholderText="Write the next decision, observation, or implementation note."
                                                     Text="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).DraftCommentBody}" />

                                            <Button x:Name="AddCommentButton"
                                                    Classes="primary"
                                                    Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).AddCommentCommand}"
                                                    Content="Add comment to selected issue" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18">
                                        <StackPanel Spacing="12">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <StackPanel>
                                                    <TextBlock Classes="section-title" Text="Attachments" />
                                                    <TextBlock Classes="muted"
                                                               Text="{Binding AttachmentCountText}" />
                                                </StackPanel>
                                                <Button x:Name="AttachFileButton"
                                                        Grid.Column="1"
                                                        Classes="secondary"
                                                        Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).AttachFileCommand}"
                                                        Content="Attach file" />
                                            </Grid>

                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasNoAttachments}"
                                                       Text="No attachment has been stored for this issue yet." />

                                            <ItemsControl ItemsSource="{Binding Attachments}"
                                                          IsVisible="{Binding HasAttachments}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:IssueAttachmentViewModel">
                                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Margin="0,0,0,10"
                                                                Padding="14">
                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                                <StackPanel Spacing="4">
                                                                    <TextBlock Text="{Binding FileName}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TrackyInkBrush}" />
                                                                    <WrapPanel>
                                                                        <TextBlock Classes="muted" Margin="0,0,12,0" Text="{Binding ContentType}" />
                                                                        <TextBlock Classes="muted" Margin="0,0,12,0" Text="{Binding SizeText}" />
                                                                        <TextBlock Classes="muted" Text="{Binding CreatedText}" />
                                                                    </WrapPanel>
                                                                </StackPanel>
                                                                <Button Grid.Column="1"
                                                                        Classes="secondary"
                                                                        Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).OpenAttachmentCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="Open" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="Reminders" />
                                            <TextBlock Classes="muted"
                                                       Text="{Binding ReminderCountText}" />

                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasNoReminders}"
                                                       Text="No reminder has been scheduled for this issue." />

                                            <ItemsControl ItemsSource="{Binding Reminders}"
                                                          IsVisible="{Binding HasReminders}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:IssueReminderViewModel">
                                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Margin="0,0,0,10"
                                                                Padding="14">
                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                                <StackPanel Spacing="6">
                                                                    <WrapPanel>
                                                                        <Border Background="{Binding StatusBadgeBackground}"
                                                                                CornerRadius="999"
                                                                                Margin="0,0,8,0"
                                                                                Padding="8,3">
                                                                            <TextBlock Text="{Binding StatusText}"
                                                                                       Foreground="{Binding StatusBadgeForeground}"
                                                                                       FontWeight="SemiBold" />
                                                                        </Border>
                                                                        <TextBlock Classes="muted"
                                                                                   Margin="0,4,0,0"
                                                                                   Text="{Binding RemindAtText}" />
                                                                    </WrapPanel>
                                                                    <TextBlock Text="{Binding Title}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TrackyInkBrush}" />
                                                                    <TextBlock Classes="muted"
                                                                               Text="{Binding Note}"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                                <Button Grid.Column="1"
                                                                        Classes="secondary"
                                                                        Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).DismissReminderCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="Dismiss" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="Comments" />
                                            <TextBlock Classes="muted"
                                                       Text="{Binding CommentCountText}" />

                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasNoComments}"
                                                       Text="No comment has been written for this issue yet." />

                                            <ItemsControl ItemsSource="{Binding Comments}"
                                                          IsVisible="{Binding HasComments}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:IssueCommentViewModel">
                                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Margin="0,0,0,10"
                                                                Padding="14">
                                                            <StackPanel Spacing="8">
                                                                <WrapPanel>
                                                                    <TextBlock Text="{Binding AuthorDisplayName}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TrackyInkBrush}" />
                                                                    <TextBlock Classes="muted"
                                                                               Margin="10,0,0,0"
                                                                               Text="{Binding CreatedText}" />
                                                                </WrapPanel>
                                                                <TextBlock Classes="body"
                                                                           Text="{Binding Body}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                            BorderBrush="{StaticResource TrackyBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="Activity" />
                                            <TextBlock Classes="muted"
                                                       Text="The timeline records issue creation, comments, state changes, and attachments." />

                                            <TextBlock Classes="muted"
                                                       IsVisible="{Binding HasNoActivity}"
                                                       Text="No activity has been recorded for this issue yet." />

                                            <ItemsControl ItemsSource="{Binding Activity}"
                                                          IsVisible="{Binding HasActivity}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:IssueActivityViewModel">
                                                        <Border Background="{StaticResource TrackySurfaceStrongBrush}"
                                                                BorderBrush="{StaticResource TrackyBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Margin="0,0,0,10"
                                                                Padding="14">
                                                            <StackPanel Spacing="6">
                                                                <WrapPanel>
                                                                    <Border Background="{StaticResource TrackyAccentSoftBrush}"
                                                                            CornerRadius="999"
                                                                            Padding="8,3">
                                                                        <TextBlock Text="{Binding EventLabel}"
                                                                                   Foreground="{StaticResource TrackyAccentBrush}"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>
                                                                    <TextBlock Classes="muted"
                                                                               Margin="10,4,0,0"
                                                                               Text="{Binding CreatedText}" />
                                                                </WrapPanel>
                                                                <TextBlock Classes="body"
                                                                           Text="{Binding Summary}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
