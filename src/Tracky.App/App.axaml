<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Tracky.App.App"
             xmlns:local="using:Tracky.App"
             RequestedThemeVariant="Default">
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <!-- GitHub Issues에 가까운 명도, 경계, 액션 색을 앱 전체 토큰으로 고정해 화면 간 톤이 흔들리지 않게 한다. -->
        <SolidColorBrush x:Key="TrackyCanvasBrush" Color="#F6F8FA" />
        <SolidColorBrush x:Key="TrackySurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TrackySurfaceStrongBrush" Color="#F6F8FA" />
        <SolidColorBrush x:Key="TrackyBorderBrush" Color="#D0D7DE" />
        <SolidColorBrush x:Key="TrackyInkBrush" Color="#24292F" />
        <SolidColorBrush x:Key="TrackyMutedInkBrush" Color="#57606A" />
        <SolidColorBrush x:Key="TrackyAccentBrush" Color="#1F883D" />
        <SolidColorBrush x:Key="TrackyAccentSoftBrush" Color="#DAFBE1" />
        <SolidColorBrush x:Key="TrackyNavBrush" Color="#24292F" />
        <SolidColorBrush x:Key="TrackyNavHoverBrush" Color="#3B434D" />
        <SolidColorBrush x:Key="TrackyNavActiveBrush" Color="#0969DA" />
        <SolidColorBrush x:Key="TrackyNavBorderBrush" Color="#57606A" />
        <SolidColorBrush x:Key="TrackyNavInkBrush" Color="#F6F8FA" />
        <SolidColorBrush x:Key="TrackyNavMutedInkBrush" Color="#8C959F" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme DensityStyle="Compact" />
    </Application.Styles>
</Application>
